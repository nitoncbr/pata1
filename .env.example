# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3000

# Required for API + DB
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional: canonical site for emails & links (default https://pataqr.com)
PUBLIC_SITE_URL=https://pataqr.com

# Waitlist welcome email (Resend)
RESEND_API_KEY=

# Other app secrets (see CLAUDE.md)
# ENCRYPTION_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
